<?xml version="1.0" encoding="UTF-8"?>
<xml>
	<pragma once="true" />

	<files id="haxe">
		<compilerflag value="-I${haxelib:hxluajit}/project/luajit/include" />
	</files>

	<files id="__main__">
		<compilerflag value="-I${haxelib:hxluajit}/project/luajit/include" />
	</files>

	<target id="haxe">
		<flag value="-fstack-protector" if="mingw" />

		<section if="mingw">
			<lib name="${haxelib:hxluajit}/project/luajit/lib/MinGW/libluajit-x86_64.a" if="HXCPP_M64" unless="HXCPP_ARM64" />
			<lib name="${haxelib:hxluajit}/project/luajit/lib/MinGW/libluajit-x86.a" if="HXCPP_M32" />
			<lib name="${haxelib:hxluajit}/project/luajit/lib/MinGW/libluajit-arm64.a" if="HXCPP_ARM64" />
			<lib name="${haxelib:hxluajit}/project/luajit/lib/MinGW/libluajit-armv7.a" if="HXCPP_ARMV7" />
		</section>

		<section if="windows" unless="mingw">
			<lib name="${haxelib:hxluajit}/project/luajit/lib/Windows/lua51-x86_64.lib" if="HXCPP_M64" unless="HXCPP_ARM64"  />
			<lib name="${haxelib:hxluajit}/project/luajit/lib/Windows/lua51-x86.lib" if="HXCPP_M32" />
			<lib name="${haxelib:hxluajit}/project/luajit/lib/Windows/lua51-arm64.lib" if="HXCPP_ARM64" />
			<lib name="${haxelib:hxluajit}/project/luajit/lib/Windows/lua51-armv7.lib" if="HXCPP_ARMV7" />
		</section>

		<section if="macos">
			<lib name="${haxelib:hxluajit}/project/luajit/lib/MacOS/libluajit.a" if="HXCPP_M64 || HXCPP_ARM64" />
		</section>

		<section if="linux">
			<lib name="${haxelib:hxluajit}/project/luajit/lib/Linux/libluajit-x86_64.a" if="HXCPP_M64" unless="HXCPP_ARM64" />
			<lib name="${haxelib:hxluajit}/project/luajit/lib/Linux/libluajit-x86.a" if="HXCPP_M32" unless="HXCPP_ARMV7" />
			<lib name="${haxelib:hxluajit}/project/luajit/lib/Linux/libluajit-arm64.a" if="HXCPP_ARM64" />
			<lib name="${haxelib:hxluajit}/project/luajit/lib/Linux/libluajit-armv7.a" if="HXCPP_ARMV7" />
		</section>

		<section if="android">
			<lib name="${haxelib:hxluajit}/project/luajit/lib/Android/libluajit-arm64.a" if="HXCPP_ARM64" />
			<lib name="${haxelib:hxluajit}/project/luajit/lib/Android/libluajit-x86_64.a" if="HXCPP_X86_64" />
			<lib name="${haxelib:hxluajit}/project/luajit/lib/Android/libluajit-armv7a.a" if="HXCPP_ARMV7" />
			<lib name="${haxelib:hxluajit}/project/luajit/lib/Android/libluajit-x86.a" if="HXCPP_X86" />
		</section>

		<section if="iphoneos">
			<lib name="${haxelib:hxluajit}/project/luajit/lib/iOS/libluajit_device.a" if="HXCPP_ARM64" />
		</section>

		<section if="iphonesim">
			<lib name="${haxelib:hxluajit}/project/luajit/lib/iOS/libluajit_sim.a" if="HXCPP_ARM64 || HXCPP_M64" />
		</section>
	</target>
</xml>
